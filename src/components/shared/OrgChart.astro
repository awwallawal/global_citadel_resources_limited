---
/**
 * OrgChart.astro — CSS-based organizational tree.
 * Desktop: horizontal layout with connecting lines.
 * Mobile: vertical indent hierarchy.
 */
import { getCollection } from 'astro:content';
import { cn } from '@/lib/utils';
import type { ClusterAccentColor } from '@/content/config';

const clusters = (await getCollection('clusters')).sort((a, b) => a.data.sortOrder - b.data.sortOrder);
const divisions = (await getCollection('divisions')).sort((a, b) => a.data.sortOrder - b.data.sortOrder);

const clustersWithDivisions = clusters.map((cluster) => ({
  name: cluster.data.name,
  slug: cluster.data.slug,
  accent: (cluster.data.accentColor ?? 'amber') as ClusterAccentColor,
  divisions: divisions.filter((d) => d.data.clusterSlug === cluster.data.slug),
}));

const accentBg: Record<ClusterAccentColor, string> = {
  amber: 'bg-cluster-amber-100',
  copper: 'bg-cluster-copper-100',
  slate: 'bg-cluster-slate-100',
};
---

{/* Desktop: horizontal tree */}
<div class="hidden lg:block">
  <div class="flex flex-col items-center">
    {/* Level 1: Holding company */}
    <div class="rounded-lg border-2 border-primary-600 bg-primary-50 px-6 py-3 font-heading text-sm font-semibold text-primary-900">
      Global Resources Citadel Limited
    </div>
    <div class="h-8 w-px bg-neutral-300" aria-hidden="true"></div>

    {/* Horizontal connector */}
    <div class="h-px w-2/3 bg-neutral-300" aria-hidden="true"></div>

    {/* Level 2: Clusters */}
    <div class="flex w-full justify-evenly">
      {clustersWithDivisions.map((cluster) => (
        <div class="flex flex-col items-center">
          <div class="h-6 w-px bg-neutral-300" aria-hidden="true"></div>
          <div class={cn('rounded-lg border border-neutral-200 px-4 py-2 text-xs font-semibold', accentBg[cluster.accent])}>
            {cluster.name}
          </div>
          <div class="h-4 w-px bg-neutral-300" aria-hidden="true"></div>
          {/* Level 3: Divisions */}
          <div class="flex flex-col gap-2">
            {cluster.divisions.map((div) => (
              <a
                href={`/divisions/${div.data.slug}/`}
                class="rounded border border-neutral-200 bg-white px-3 py-1.5 text-center text-xs text-neutral-700 motion-safe:transition-colors hover:border-primary-300 hover:text-primary-600 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 focus-visible:ring-offset-2"
              >
                {div.data.name}
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</div>

{/* Mobile: vertical indent tree */}
<div class="lg:hidden">
  <div class="space-y-3">
    <div class="rounded-lg border-2 border-primary-600 bg-primary-50 px-4 py-2 font-heading text-sm font-semibold text-primary-900">
      Global Resources Citadel Limited
    </div>
    {clustersWithDivisions.map((cluster) => (
      <div class="ml-6 border-l-2 border-neutral-200 pl-4">
        <div class={cn('inline-block rounded-lg px-3 py-1.5 text-xs font-semibold', accentBg[cluster.accent])}>
          {cluster.name}
        </div>
        <div class="ml-4 mt-1 space-y-1">
          {cluster.divisions.map((div) => (
            <a
              href={`/divisions/${div.data.slug}/`}
              class="flex min-h-11 items-center rounded text-xs text-neutral-600 hover:text-primary-600 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 focus-visible:ring-offset-2"
            >
              {div.data.name}
            </a>
          ))}
        </div>
      </div>
    ))}
  </div>
</div>
