---
import { cn } from '@/lib/utils';
import { buttonVariants } from '@/components/ui/button';

interface Props {
  heading: string;
  body: string;
  primaryCta: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  class?: string;
}

const { heading, body, primaryCta, secondaryCta, class: className } = Astro.props;
---

<section class={cn('bg-neutral-900 py-16 text-center lg:py-24', className)}>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto mb-7 h-[--height-divider] w-15 bg-gold-600" aria-hidden="true"></div>
    <h2 class="font-heading text-2xl font-bold leading-tight text-white lg:text-4xl">
      {heading}
    </h2>
    <p class="mx-auto mb-9 mt-4 max-w-lg text-lg leading-relaxed text-neutral-400">
      {body}
    </p>
    <div class="flex flex-wrap items-center justify-center gap-4">
      <a
        href={primaryCta.href}
        class={cn(buttonVariants({ variant: 'gold', size: 'default' }), 'focus-visible:ring-offset-neutral-900')}
      >
        {primaryCta.label}
      </a>
      {secondaryCta && (
        <a
          href={secondaryCta.href}
          class="inline-flex items-center justify-center rounded-lg border border-neutral-600 px-8 py-4 font-semibold text-white motion-safe:transition-all motion-safe:duration-200 motion-safe:ease-out hover:bg-neutral-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 focus-visible:ring-offset-2 focus-visible:ring-offset-neutral-900"
        >
          {secondaryCta.label}
        </a>
      )}
    </div>
  </div>
</section>
