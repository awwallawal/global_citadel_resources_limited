---
/**
 * CredentialCard.astro — Displays a certification or credential.
 * Shows placeholder icon, certification name, and issuing body.
 */

interface Props {
  name: string;
  issuer: string;
}

const { name, issuer } = Astro.props;
---

<div class="rounded-lg border border-neutral-200 p-4 text-center">
  {/* Placeholder icon */}
  <div class="mx-auto mb-3 flex h-10 w-10 items-center justify-center rounded-full bg-primary-50" aria-hidden="true">
    <svg
      class="h-5 w-5 text-primary-600"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z" />
      <circle cx="12" cy="12" r="3" />
    </svg>
  </div>
  <h3 class="font-heading text-sm font-semibold text-neutral-900">{name}</h3>
  <p class="mt-1 text-xs text-neutral-500">{issuer}</p>
</div>
