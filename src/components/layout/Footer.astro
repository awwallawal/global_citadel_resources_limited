---
/**
 * Footer.astro — Site footer with brand row, 7-column link grid, and copyright bar.
 * Zero client-side JS. Mobile accordion uses native <details>/<summary>.
 */
import { Image } from 'astro:assets';
import legacyLogo from '@/assets/brand/logo-legacy.png';
import { COMPANY } from '@/lib/company';

interface FooterLink {
  label: string;
  href: string;
  external?: boolean;
}

interface FooterColumn {
  title: string;
  links: FooterLink[];
}

const columns: FooterColumn[] = [
  {
    title: 'The Group',
    links: [
      { label: 'About the Group', href: '/about/' },
      { label: 'Leadership', href: '/about/#leadership' },
      { label: 'Group Structure', href: '/about/#group-structure' },
      { label: 'Community Impact', href: '/community-impact/' },
      { label: 'Credentials', href: '/about/#credentials' },
    ],
  },
  {
    title: 'Divisions',
    links: [
      { label: 'Crop Farming', href: '/divisions/crop-farming/' },
      { label: 'Animal Husbandry', href: '/divisions/animal-husbandry/' },
      { label: 'Agro-Processing', href: '/divisions/agro-processing/' },
      { label: 'Commodity Marketing', href: '/divisions/commodity-marketing/' },
    ],
  },
  {
    title: 'More Divisions',
    links: [
      { label: 'Import & Export', href: '/divisions/import-export/' },
      { label: 'Travel & Mobility', href: '/divisions/travel-mobility/' },
      { label: 'Real Estate', href: '/divisions/real-estate/' },
      { label: 'Oil & Gas', href: '/divisions/oil-gas/' },
      { label: 'View All Divisions', href: '/divisions/' },
    ],
  },
  {
    title: 'Insights',
    links: [
      { label: 'Latest', href: '/insights/latest/' },
      { label: 'News & Updates', href: '/insights/news/' },
      { label: 'Thought Leadership', href: '/insights/thought-leadership/' },
    ],
  },
  {
    title: 'Get In Touch',
    links: [
      { label: 'General Enquiries', href: '/contact/general/' },
      { label: 'Contact by Division', href: '/contact/divisions/' },
      { label: 'Partner / Investor', href: '/contact/strategic/' },
      { label: 'Locations', href: '/contact/locations/' },
    ],
  },
  {
    title: 'Investors & Partners',
    links: [
      { label: 'Why Partner With Us', href: '/investors-partners/' },
      { label: 'Portfolio Strength', href: '/investors-partners/#portfolio' },
      { label: 'Strategic Inquiry', href: '/contact/strategic/' },
    ],
  },
  {
    title: 'Connect',
    links: [
      { label: 'LinkedIn', href: '#', external: true },
      { label: 'Twitter / X', href: '#', external: true },
      { label: 'Email', href: `mailto:${COMPANY.defaultEmail}`, external: true },
    ],
  },
];

const legalLinks = [
  { label: 'Privacy Policy', href: '/privacy-policy/' },
  { label: 'Terms of Use', href: '/terms/' },
  { label: 'Sitemap', href: '/sitemap/' },
];

const currentYear = new Date().getFullYear();

const linkClasses =
  'block py-3 text-sm text-neutral-400 transition-colors hover:text-white focus-visible:rounded focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 focus-visible:ring-offset-2 focus-visible:ring-offset-neutral-900';

const headingClasses =
  'font-heading text-xs font-semibold uppercase tracking-widest text-gold-600';
---

<footer class="bg-neutral-900 px-6 pb-8 pt-18">
  <div class="mx-auto max-w-7xl">

    {/* ── Row 1: Brand Story ── */}
    <div class="mb-12 border-b border-white/[0.08] pb-10">
      <a
        href="/"
        class="mb-3 inline-block rounded-lg focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 focus-visible:ring-offset-2 focus-visible:ring-offset-neutral-900"
        aria-label="Global Resources Citadel - Home"
      >
        <Image
          src={legacyLogo}
          alt="Global Resources Citadel"
          width={56}
          height={62}
          class="h-14 w-auto"
          loading="lazy"
        />
      </a>
      <p class="max-w-xl text-body-sm leading-relaxed text-neutral-400">
        {COMPANY.legalName} is a pan-African conglomerate headquartered in Lagos with a UK office in Bromley, building
        integrated value chains across agriculture, trade, real estate, and energy.
        Eight business divisions working together to strengthen economic foundations across the continent.
      </p>
    </div>

    {/* ── Row 2: Link Grid ── */}

    {/* Desktop: full 7-column grid (lg+) */}
    <nav aria-label="Footer navigation" class="mb-12 hidden lg:grid lg:grid-cols-7 lg:gap-8">
      {columns.map((col) => (
        <div>
          <h2 class={headingClasses}>{col.title}</h2>
          <ul class="mt-3.5 space-y-0.5">
            {col.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class={linkClasses}
                  {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </nav>

    {/* Mobile: accordion pattern via <details>/<summary> (below lg) */}
    <nav aria-label="Footer navigation — mobile" class="mb-12 lg:hidden">
      {columns.map((col) => (
        <details class="group border-b border-white/[0.06]">
          <summary class="flex cursor-pointer list-none items-center justify-between py-4">
            <span class={headingClasses}>{col.title}</span>
            <svg
              class="h-4 w-4 shrink-0 text-neutral-400 transition-transform group-open:rotate-180"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="m6 9 6 6 6-6" />
            </svg>
          </summary>
          <ul class="pb-4">
            {col.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class={linkClasses}
                  {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </details>
      ))}
    </nav>

    {/* ── Row 3: Copyright Bar ── */}
    <div class="border-t border-white/[0.06] pt-6 text-center text-caption text-neutral-400">
      <p>&copy; {currentYear} {COMPANY.legalName}. All rights reserved. <span class="text-neutral-500">RC No.&nbsp;{COMPANY.rcNumber}</span></p>
      <div class="mt-2 flex flex-wrap items-center justify-center gap-x-1">
        {legalLinks.map((link, i) => (
          <>
            {i > 0 && <span class="text-neutral-500" aria-hidden="true">|</span>}
            <a
              href={link.href}
              class="inline-flex min-h-11 items-center px-2 text-neutral-400 transition-colors hover:text-white focus-visible:rounded focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 focus-visible:ring-offset-2 focus-visible:ring-offset-neutral-900"
            >
              {link.label}
            </a>
          </>
        ))}
      </div>
    </div>

  </div>
</footer>
