---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import DesktopNav from '@/components/navigation/DesktopNav';
import MobileNav from '@/components/navigation/MobileNav';
import SearchOverlay from '@/components/search/SearchOverlay';
import { buildSearchIndex } from '@/lib/search';
import emblemLogo from '@/assets/brand/grcl-emblem.png';

interface Props {
  currentPath: string;
  headerVariant?: 'solid' | 'transparent';
}

const { currentPath, headerVariant = 'solid' } = Astro.props;

const searchIndex = await buildSearchIndex();
const allDivisions = await getCollection('divisions');
const allClusters = await getCollection('clusters');

const divisions = allDivisions
  .sort((a, b) => a.data.sortOrder - b.data.sortOrder)
  .map((d) => ({
    name: d.data.name,
    slug: d.data.slug,
    clusterSlug: d.data.clusterSlug,
  }));

const clusters = allClusters
  .sort((a, b) => a.data.sortOrder - b.data.sortOrder)
  .map((c) => ({
    name: c.data.name,
    slug: c.data.slug,
  }));
---

<header
  class:list={[
    'top-0 z-50',
    headerVariant === 'transparent' ? 'fixed inset-x-0' : 'sticky',
  ]}
  data-variant={headerVariant}
>
  <DesktopNav
    client:load
    divisions={divisions}
    clusters={clusters}
    currentPath={currentPath}
    headerVariant={headerVariant}
  />

  <!-- Mobile header bar: [Logo] [Search] [Hamburger] -->
  <div
    data-mobile-bar
    class:list={[
      'flex md:hidden items-center justify-between px-4 h-16 backdrop-blur-lg',
      'motion-safe:transition-[background-color,border-color] motion-safe:duration-300',
      headerVariant === 'transparent'
        ? 'bg-transparent border-b border-transparent'
        : 'bg-white/95 border-b border-neutral-300',
    ]}
  >
    <a
      href="/"
      class="shrink-0 rounded-lg focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 focus-visible:ring-offset-2"
      aria-label="Global Resources Citadel - Home"
    >
      <Image
        src={emblemLogo}
        alt="Global Resources Citadel"
        width={40}
        height={40}
        class="h-10 w-auto"
      />
    </a>

    <div class="flex items-center gap-1">
      <!-- Standalone mobile search icon -->
      <a
        href="/search/"
        data-mobile-search
        class:list={[
          'min-h-11 min-w-11 inline-flex items-center justify-center rounded-lg motion-safe:transition-colors motion-safe:duration-300 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 focus-visible:ring-offset-2',
          headerVariant === 'transparent'
            ? 'text-white hover:text-white/80'
            : 'text-neutral-600 hover:text-neutral-900 hover:bg-neutral-100',
        ]}
        aria-label="Search"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.3-4.3"></path>
        </svg>
      </a>

      <!-- Hamburger trigger (MobileNav) -->
      <MobileNav
        client:load
        divisions={divisions}
        clusters={clusters}
        currentPath={currentPath}
        headerVariant={headerVariant}
      />
    </div>
  </div>

  <SearchOverlay client:idle index={searchIndex} />
</header>

{/* Scroll-based transparent → solid transition for mobile bar.
    CSS uses is:global because selectors must reach into the React MobileNav island.
    Both style and script self-guard via [data-variant="transparent"] — no-op on solid pages. */}
<style is:global>
  header[data-variant="transparent"][data-scrolled] [data-mobile-bar] {
    background-color: color-mix(in srgb, white 95%, transparent);
    border-bottom-color: var(--color-neutral-300);
  }
  header[data-variant="transparent"][data-scrolled] [data-mobile-search] {
    color: var(--color-neutral-600);
  }
  header[data-variant="transparent"][data-scrolled] [data-mobile-search]:hover {
    color: var(--color-neutral-900);
  }
  header[data-variant="transparent"][data-scrolled] [aria-label="Open navigation menu"] {
    color: var(--color-neutral-600);
  }
  header[data-variant="transparent"][data-scrolled] [aria-label="Open navigation menu"]:hover {
    color: var(--color-neutral-900);
  }
</style>

<script>
  const header = document.querySelector('header[data-variant="transparent"]');
  if (header) {
    let rafId = 0;
    function onScroll() {
      cancelAnimationFrame(rafId);
      rafId = requestAnimationFrame(() => {
        if (window.scrollY > 50) {
          header!.setAttribute('data-scrolled', '');
        } else {
          header!.removeAttribute('data-scrolled');
        }
      });
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }
</script>
