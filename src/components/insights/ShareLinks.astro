---
/**
 * ShareLinks.astro — Social sharing links for article pages.
 * LinkedIn and Twitter/X via URL intent, Copy Link via clipboard API with inline script.
 */
import { cn } from '@/lib/utils';

interface Props {
  url: string;
  title: string;
  layout?: 'vertical' | 'horizontal';
}

const { url, title, layout = 'vertical' } = Astro.props;
const encodedUrl = encodeURIComponent(url);
const encodedTitle = encodeURIComponent(title);

const linkClass =
  'flex h-10 w-10 items-center justify-center rounded-lg border border-neutral-200 text-neutral-500 motion-safe:transition-colors hover:border-primary-300 hover:text-primary-600 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 focus-visible:ring-offset-2';
---

<div class={cn('flex gap-3', layout === 'vertical' ? 'flex-col' : 'flex-row')}>
  <a
    href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`}
    target="_blank"
    rel="noopener noreferrer"
    class={linkClass}
    aria-label="Share on LinkedIn"
    title="Share on LinkedIn"
  >
    <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
    </svg>
  </a>

  <a
    href={`https://twitter.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}`}
    target="_blank"
    rel="noopener noreferrer"
    class={linkClass}
    aria-label="Share on X"
    title="Share on X"
  >
    <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
    </svg>
  </a>

  <button
    type="button"
    class={linkClass}
    aria-label="Copy link to clipboard"
    title="Copy link to clipboard"
    data-copy-url={url}
  >
    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244" />
    </svg>
  </button>
  <span class="sr-only" aria-live="polite" data-copy-status></span>
</div>

<script>
  document.querySelectorAll('[data-copy-url]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const url = btn.getAttribute('data-copy-url');
      if (!url) return;
      const status = btn.closest('div')?.querySelector('[data-copy-status]');
      try {
        await navigator.clipboard.writeText(url);
        const svg = btn.querySelector('svg');
        if (svg) {
          svg.style.color = 'var(--color-primary-600)';
          setTimeout(() => { svg.style.color = ''; }, 2000);
        }
        if (status) {
          status.textContent = 'Link copied to clipboard';
          setTimeout(() => { status.textContent = ''; }, 2000);
        }
      } catch {
        if (status) {
          status.textContent = 'Unable to copy link';
          setTimeout(() => { status.textContent = ''; }, 2000);
        }
      }
    });
  });
</script>
