---
import { getCollection } from 'astro:content';
import PageLayout from '@/layouts/PageLayout.astro';
import SectionWrapper from '@/components/layout/SectionWrapper.astro';
import SectionHeading from '@/components/layout/SectionHeading.astro';
import DivisionBentoGrid from '@/components/divisions/DivisionBentoGrid.astro';
import CredibilityBar from '@/components/shared/CredibilityBar.astro';
import InsightCard from '@/components/insights/InsightCard.astro';
import FAQSection from '@/components/shared/FAQSection.astro';
import CTABanner from '@/components/shared/CTABanner.astro';
import {
  generateMetadata,
  generateOrganizationJsonLd,
  generateWebSiteJsonLd,
} from '@/lib/seo';
import { validateContentIntegrity } from '@/lib/content-validation';

await validateContentIntegrity();

const clusters = (await getCollection('clusters')).sort(
  (a, b) => a.data.sortOrder - b.data.sortOrder,
);

const divisions = await getCollection('divisions');

const articles = (await getCollection('articles'))
  .sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime())
  .slice(0, 3);

const streamLabels: Record<string, string> = {
  'company-news': 'News & Updates',
  'announcements': 'News & Updates',
  'operational-updates': 'News & Updates',
  'thought-leadership': 'Thought Leadership',
  'industry-commentary': 'Industry Analysis',
  'division-insight': 'Division Insight',
};

const seo = {
  ...generateMetadata({
    title: "Building Nigeria's Future Across Seven Sectors",
    description:
      'Global Resources Citadel Limited is a diversified Nigerian conglomerate operating across agriculture, trade, real estate, and energy. Seven divisions driving economic growth.',
    path: '/',
  }),
  jsonLd: [generateOrganizationJsonLd(), generateWebSiteJsonLd()],
};

/**
 * Inline SVG icons for cluster cards — avoids shipping lucide-react client JS.
 * Paths sourced from lucide icon set: Wheat, TrendingUp, Building2.
 */
const clusterIcons: Record<string, string> = {
  'agriculture-processing': '<path d="M2 22 16 8"/><path d="M3.47 12.53 5 11l1.53 1.53a3.5 3.5 0 0 1 0 4.94L5 19l-1.53-1.53a3.5 3.5 0 0 1 0-4.94Z"/><path d="M7.47 8.53 9 7l1.53 1.53a3.5 3.5 0 0 1 0 4.94L9 15l-1.53-1.53a3.5 3.5 0 0 1 0-4.94Z"/><path d="M11.47 4.53 13 3l1.53 1.53a3.5 3.5 0 0 1 0 4.94L13 11l-1.53-1.53a3.5 3.5 0 0 1 0-4.94Z"/><path d="M20 2h2v2a4 4 0 0 1-4 4h-2V6a4 4 0 0 1 4-4Z"/><path d="M11.47 17.47 13 19l-1.53 1.53a3.5 3.5 0 0 1-4.94 0L5 19l1.53-1.53a3.5 3.5 0 0 1 4.94 0Z"/><path d="M15.47 13.47 17 15l-1.53 1.53a3.5 3.5 0 0 1-4.94 0L9 15l1.53-1.53a3.5 3.5 0 0 1 4.94 0Z"/><path d="M19.47 9.47 21 11l-1.53 1.53a3.5 3.5 0 0 1-4.94 0L13 11l1.53-1.53a3.5 3.5 0 0 1 4.94 0Z"/>',
  'trade-markets': '<polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/>',
  'built-environment-energy': '<path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/><path d="M10 6h4"/><path d="M10 10h4"/><path d="M10 14h4"/><path d="M10 18h4"/>',
};
---

<PageLayout seo={seo} headerVariant="transparent">

  {/* ── Hero Section ── */}
  <section class="hero-section relative flex min-h-hero-mobile items-center justify-center overflow-hidden bg-gradient-to-br from-primary-900 to-primary-700 px-6 py-36 text-center lg:min-h-screen lg:py-40">
    <div class="relative z-10 mx-auto max-w-4xl">
      <h1 class="mx-auto max-w-hero font-heading text-4xl font-bold leading-tight tracking-tight text-white sm:text-5xl lg:text-6xl">
        Building Nigeria's Future Across Seven Sectors
      </h1>
      <p class="mx-auto mt-5 max-w-hero-subtitle text-base leading-relaxed text-white/80 sm:text-lg lg:text-xl">
        From agriculture to energy, Global Resources Citadel is creating integrated
        value chains that drive economic growth and opportunity.
      </p>
      <div class="mt-9 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a
          href="/divisions/"
          class="inline-flex min-h-11 items-center justify-center rounded-lg bg-gold-600 px-8 py-4 text-base font-bold text-primary-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-primary-900 motion-safe:transition-all motion-safe:duration-200 motion-safe:hover:-translate-y-px motion-safe:hover:bg-gold-400"
        >
          Explore Our Divisions
        </a>
        <a
          href="/investors-partners/"
          class="inline-flex min-h-11 items-center justify-center rounded-lg border border-white/30 px-8 py-4 text-base font-bold text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-primary-900 motion-safe:transition-all motion-safe:duration-200 motion-safe:hover:bg-white/10"
        >
          Partner With Us
        </a>
      </div>
    </div>
  </section>

  {/* ── Business Overview Section ── */}
  <SectionWrapper variant="light">
    <div class="mx-auto max-w-overview">
      <SectionHeading
        eyebrow="Our Business"
        subtitle="Global Resources Citadel operates across interconnected sectors, each strengthening the others. Our agricultural foundation feeds our processing capacity. Our trade networks connect our products to markets. Our infrastructure investments build the platforms for future growth."
      >
        A Multi-Division Business Built for Scale
      </SectionHeading>

      <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
        {clusters.map((cluster) => (
          <a
            href={`/divisions/${cluster.data.slug}/`}
            class="group block border-l-2 border-gold-600 py-2 pl-5 focus-visible:rounded focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 focus-visible:ring-offset-2 motion-safe:transition-colors motion-safe:hover:border-gold-400"
          >
            <svg
              class="mb-2 h-6 w-6 text-gold-600"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              set:html={clusterIcons[cluster.data.slug] ?? ''}
            />
            <h3 class="font-heading text-base font-bold text-neutral-900 motion-safe:transition-colors group-hover:text-primary-600">
              {cluster.data.name}
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-neutral-600">
              {cluster.data.tagline}
            </p>
          </a>
        ))}
      </div>
    </div>
  </SectionWrapper>

  {/* ── Divisions Bento Grid ── */}
  <SectionWrapper variant="default">
    <SectionHeading
      eyebrow="Our Divisions"
      centered
    >
      Seven Verticals. One Vision.
    </SectionHeading>
    <DivisionBentoGrid divisions={divisions} />
  </SectionWrapper>

  {/* ── Credibility Stats ── */}
  <CredibilityBar
    stats={[
      { value: 7, label: 'Divisions Active' },
      { value: 15, label: 'Years in Business', suffix: '+' },
      { value: 6, label: 'Nigerian States' },
      { value: 40, label: 'Business Partners', suffix: '+' },
    ]}
  />

  {/* ── Latest Insights ── */}
  <SectionWrapper variant="default">
    <SectionHeading eyebrow="Insights" centered>
      Latest Thinking
    </SectionHeading>

    {articles.length === 0 ? (
      <p class="text-center text-lg text-neutral-500">
        Stay tuned for insights from across our divisions.
      </p>
    ) : (
      <>
        <div class="insights-grid">
          {articles.map((article, i) => (
            <InsightCard
              title={article.data.title}
              excerpt={article.data.excerpt}
              category={streamLabels[article.data.stream] ?? article.data.stream}
              href={`/insights/${article.id}/`}
              variant={i === 0 ? 'featured' : 'standard'}
              class={i === 0 ? 'insight-featured' : ''}
            />
          ))}
        </div>

        <div class="mt-10 text-center">
          <a
            href="/insights/"
            class="inline-flex items-center gap-1.5 text-sm font-semibold text-gold-600 hover:text-gold-400 focus-visible:rounded focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 focus-visible:ring-offset-2"
          >
            View All Insights <span aria-hidden="true">&rarr;</span>
          </a>
        </div>
      </>
    )}
  </SectionWrapper>

  {/* ── FAQ Section ── */}
  <FAQSection category="homepage" sectionTitle="Frequently Asked Questions" variant="default" />

  {/* ── Contact CTA ── */}
  <CTABanner
    heading="Ready to Work With Us?"
    body="Whether you're an investor, partner, or potential collaborator, we'd welcome the opportunity to explore how we can create mutual value."
    primaryCta={{ label: 'Contact Us', href: '/contact/' }}
    secondaryCta={{ label: 'Partner With Us', href: '/contact/strategic/' }}
    variant="gold"
  />
</PageLayout>

<style>
  .insights-grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 768px) {
    .insights-grid {
      grid-template-columns: 1.4fr 1fr;
    }
    .insights-grid :global(.insight-featured) {
      grid-row: 1 / 3;
    }
  }

  .hero-section::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(180, 138, 62, 0.15) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }

  .hero-section::after {
    content: '';
    position: absolute;
    bottom: -30%;
    left: -10%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(34, 197, 94, 0.1) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-section::before,
    .hero-section::after {
      display: none;
    }
  }
</style>
