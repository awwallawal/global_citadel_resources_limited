---
import PageLayout from '@/layouts/PageLayout.astro';
import SectionWrapper from '@/components/layout/SectionWrapper.astro';
import SectionHeading from '@/components/layout/SectionHeading.astro';
import CTABanner from '@/components/shared/CTABanner.astro';
import { generateMetadata, generateOrganizationJsonLd } from '@/lib/seo';
import { validateContentIntegrity } from '@/lib/content-validation';

await validateContentIntegrity();

const seo = {
  ...generateMetadata({
    title: 'Home',
    description:
      'Global Resources Citadel Limited — a Nigerian conglomerate operating across agriculture, trade, real estate, and energy.',
    path: '/',
  }),
  jsonLd: generateOrganizationJsonLd(),
};
---

<PageLayout seo={seo}>
  <SectionWrapper variant="hero">
    <h1 class="font-heading text-4xl font-semibold leading-tight text-white lg:text-6xl">
      Building Nigeria's Future
    </h1>
    <p class="mt-6 max-w-2xl text-lg text-primary-100">
      A diversified conglomerate delivering value across agriculture, trade, real estate, and energy.
    </p>
  </SectionWrapper>

  <SectionWrapper variant="light">
    <SectionHeading eyebrow="Our Business" subtitle="Driving growth across seven strategic divisions." centered>
      The GRCL Advantage
    </SectionHeading>
  </SectionWrapper>

  <CTABanner
    heading="Ready to Partner With Us?"
    body="Explore opportunities with one of Nigeria's most diversified conglomerates."
    primaryCta={{ label: 'Get in Touch', href: '/contact' }}
  />
</PageLayout>
