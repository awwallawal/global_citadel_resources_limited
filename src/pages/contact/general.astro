---
/**
 * General Enquiries — Contact form for general questions about GRCL.
 * Sidebar shows contact information (phone, email, address, hours).
 */
import PageLayout from '@/layouts/PageLayout.astro';
import BreadcrumbNav from '@/components/layout/BreadcrumbNav.astro';
import SectionWrapper from '@/components/layout/SectionWrapper.astro';
import InquiryForm from '@/components/contact/InquiryForm.tsx';
import ContactSidebar from '@/components/contact/ContactSidebar.astro';
import {
  generateMetadata,
  generateBreadcrumbJsonLd,
  type BreadcrumbItem,
} from '@/lib/seo';

const breadcrumbs: BreadcrumbItem[] = [
  { label: 'Home', href: '/' },
  { label: 'Contact', href: '/contact/' },
  { label: 'General Enquiries' },
];

const seo = {
  ...generateMetadata({
    title: 'General Enquiries — Contact',
    description:
      'Send a general enquiry to Global Resources Citadel Limited. We aim to respond within 2 business days.',
    path: '/contact/general/',
  }),
  jsonLd: [generateBreadcrumbJsonLd(breadcrumbs)],
};
---

<PageLayout seo={seo}>
  <BreadcrumbNav items={breadcrumbs} slot="breadcrumb" />

  <SectionWrapper variant="default">
    <div class="mx-auto max-w-3xl">
      <h1 class="font-heading text-3xl font-bold leading-tight tracking-tight lg:text-4xl">
        General Enquiries
      </h1>
      <p class="mt-3 text-lg text-neutral-600">
        Send us a general message about Global Resources Citadel.
      </p>
    </div>

    <div class="mx-auto mt-10 grid max-w-3xl grid-cols-1 gap-8 lg:max-w-none lg:grid-cols-3 lg:gap-12">
      <div class="lg:col-span-2">
        <InquiryForm client:visible variant="general" />
        <p class="mt-6 text-sm text-neutral-500">
          We aim to respond within 2 business days.
        </p>
      </div>

      <ContactSidebar variant="general" />
    </div>
  </SectionWrapper>
</PageLayout>
