---
/**
 * Division Inquiry Form — Dynamic page for each of the 7 divisions.
 * Renders a division-specific inquiry form with sidebar context.
 * Form submission is NOT implemented here — see Story 4.4.
 */
import { getCollection } from 'astro:content';
import PageLayout from '@/layouts/PageLayout.astro';
import BreadcrumbNav from '@/components/layout/BreadcrumbNav.astro';
import SectionWrapper from '@/components/layout/SectionWrapper.astro';
import InquiryForm from '@/components/contact/InquiryForm.tsx';
import {
  generateMetadata,
  generateBreadcrumbJsonLd,
  type BreadcrumbItem,
} from '@/lib/seo';
import type { Division } from '@/content/config';

export async function getStaticPaths() {
  const divisions = await getCollection('divisions');

  return Promise.all(
    divisions.map(async (division) => {
      return {
        params: { division: division.data.slug },
        props: {
          division: division.data,
        },
      };
    }),
  );
}

interface Props {
  division: Division;
}

const { division } = Astro.props;

const breadcrumbs: BreadcrumbItem[] = [
  { label: 'Home', href: '/' },
  { label: 'Contact', href: '/contact/' },
  { label: 'Contact by Division', href: '/contact/divisions/' },
  { label: division.name },
];

const seo = {
  ...generateMetadata({
    title: `${division.name} Enquiry — Contact`,
    description: `Submit an enquiry to our ${division.name} team. We aim to respond within 2 business days.`,
    path: `/contact/divisions/${division.slug}/`,
  }),
  jsonLd: [generateBreadcrumbJsonLd(breadcrumbs)],
};
---

<PageLayout seo={seo}>
  <BreadcrumbNav items={breadcrumbs} slot="breadcrumb" />

  <SectionWrapper variant="default">
    <div class="mx-auto max-w-3xl">
      <h1 class="font-heading text-3xl font-bold leading-tight tracking-tight lg:text-4xl">
        {division.name} Enquiry
      </h1>
      <p class="mt-3 text-lg text-neutral-600">
        Get in touch with our {division.name} team.
      </p>
    </div>

    <div class="mx-auto mt-10 grid max-w-3xl grid-cols-1 gap-8 lg:max-w-none lg:grid-cols-3 lg:gap-12">
      {/* Form (2/3 width on desktop) */}
      <div class="lg:col-span-2">
        <InquiryForm
          client:visible
          variant="division"
          divisionSlug={division.slug}
          divisionName={division.name}
        />
        <p class="mt-6 text-sm text-neutral-500">
          Your enquiry will be routed to our {division.name} team. We aim to respond within 2 business days.
        </p>
      </div>

      {/* Sidebar (1/3 width on desktop) */}
      <aside class="lg:col-span-1">
        <div class="rounded-xl border border-neutral-200 p-6">
          <h2 class="font-heading text-base font-semibold text-neutral-900">
            About {division.name}
          </h2>
          <p class="mt-3 text-sm leading-relaxed text-neutral-600">
            {division.tagline}
          </p>
          <a
            href={`/divisions/${division.slug}/`}
            class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-primary-600 motion-safe:transition-colors hover:text-primary-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 focus-visible:ring-offset-2"
          >
            Explore {division.name} <span aria-hidden="true">&rarr;</span>
          </a>
        </div>
      </aside>
    </div>
  </SectionWrapper>
</PageLayout>
