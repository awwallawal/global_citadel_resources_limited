---
import PageLayout from '@/layouts/PageLayout.astro';
import SectionWrapper from '@/components/layout/SectionWrapper.astro';
import BreadcrumbNav from '@/components/layout/BreadcrumbNav.astro';
import {
  generateMetadata,
  generateBreadcrumbJsonLd,
  type BreadcrumbItem,
} from '@/lib/seo';

const breadcrumbs: BreadcrumbItem[] = [
  { label: 'Home', href: '/' },
  { label: 'Terms of Use' },
];

const seo = {
  ...generateMetadata({
    title: 'Terms of Use',
    description: 'Terms of use for the Global Resources Citadel Limited website.',
    path: '/terms/',
  }),
  jsonLd: [generateBreadcrumbJsonLd(breadcrumbs)],
};
---

<PageLayout seo={seo}>
  <BreadcrumbNav items={breadcrumbs} slot="breadcrumb" />

  <SectionWrapper>
    <div class="mx-auto max-w-article">
      <h1 class="font-heading text-3xl font-bold lg:text-4xl">Terms of Use</h1>
      <p class="mt-2 text-sm text-neutral-500">Last Updated: March 2026</p>

      <div class="prose-legal mt-10">
        <p>These terms of use govern your access to and use of the Global Resources Citadel Limited (RC No. 1801787) ("GRCL", "we", "us", or "our") website. By accessing or using this website, you agree to be bound by these terms.</p>

        <h2>Acceptance of Terms</h2>
        <p>By accessing this website, you confirm that you have read, understood, and agree to be bound by these terms of use. If you do not agree with any part of these terms, you should not use this website.</p>
        <p>We reserve the right to modify these terms at any time. Changes will be effective immediately upon posting on this page. Your continued use of the website after any changes constitutes acceptance of the revised terms.</p>

        <h2>Use of Site</h2>
        <p>You may use this website for lawful purposes only. You agree not to:</p>
        <ul>
          <li>Use the site in any way that violates applicable laws or regulations</li>
          <li>Attempt to gain unauthorised access to any part of the website or its systems</li>
          <li>Introduce viruses, malware, or other harmful material</li>
          <li>Interfere with the proper functioning of the website</li>
          <li>Collect or harvest information about other users without their consent</li>
          <li>Use the site for any commercial purpose without our written permission</li>
        </ul>

        <h2>Intellectual Property</h2>
        <p>All content on this website — including text, graphics, logos, images, and software — is the property of Global Resources Citadel Limited or its content suppliers and is protected by Nigerian and international copyright, trademark, and intellectual property laws.</p>
        <p>The GRC monogram, Global Resources Citadel wordmark, and associated brand elements are trademarks of Global Resources Citadel Limited. You may not reproduce, distribute, or create derivative works from any content on this site without our express written permission.</p>

        <h2>Disclaimer of Warranties</h2>
        <p>This website and its content are provided on an "as is" and "as available" basis. GRCL makes no representations or warranties of any kind, express or implied, regarding the completeness, accuracy, reliability, suitability, or availability of the website or the information contained on it.</p>
        <p>We do not guarantee that the website will be uninterrupted, error-free, or free of viruses or other harmful components.</p>

        <h2>Limitation of Liability</h2>
        <p>To the fullest extent permitted by law, Global Resources Citadel Limited shall not be liable for any indirect, incidental, special, consequential, or punitive damages, or any loss of profits or revenues, whether incurred directly or indirectly, arising from your use of or inability to use this website.</p>
        <p>In no event shall our total liability exceed the amount you paid us, if any, for accessing the website.</p>

        <h2>Governing Law</h2>
        <p>These terms shall be governed by and construed in accordance with the laws of the Federal Republic of Nigeria. Any disputes arising from these terms or your use of the website shall be subject to the exclusive jurisdiction of the courts of Nigeria.</p>

        <h2>Contact</h2>
        <p>If you have questions about these terms of use, please contact us at <a href="mailto:info@global-resources.org">info@global-resources.org</a> or through our <a href="/contact/general/">general enquiry form</a>.</p>

        <p class="mt-8 text-xs italic text-neutral-400">These terms of use are placeholder content for structural and layout purposes. All legal text must be reviewed and approved by a qualified legal professional before production launch.</p>
      </div>
    </div>
  </SectionWrapper>
</PageLayout>

<style>
  .prose-legal {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-neutral-600);
  }
  .prose-legal h2 {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    color: var(--color-neutral-900);
  }
  .prose-legal h3 {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    color: var(--color-neutral-900);
  }
  .prose-legal p { margin-bottom: 1rem; }
  .prose-legal ul, .prose-legal ol {
    list-style-type: disc;
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }
  .prose-legal ol { list-style-type: decimal; }
  .prose-legal li { margin-bottom: 0.375rem; }
  .prose-legal a {
    color: var(--color-primary-600);
    text-decoration: underline;
    border-radius: 2px;
  }
  .prose-legal a:hover { color: var(--color-primary-700); }
  .prose-legal a:focus-visible {
    outline: 2px solid var(--color-primary-500);
    outline-offset: 2px;
  }
</style>
