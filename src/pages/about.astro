---
/**
 * About the Group — Corporate overview, mission, vision, leadership,
 * group structure, credentials, and CTA.
 */
import { getEntry, getCollection, render } from 'astro:content';
import PageLayout from '@/layouts/PageLayout.astro';
import BreadcrumbNav from '@/components/layout/BreadcrumbNav.astro';
import SectionWrapper from '@/components/layout/SectionWrapper.astro';
import SectionHeading from '@/components/layout/SectionHeading.astro';
import AnchorNav from '@/components/shared/AnchorNav.astro';
import FAQSection from '@/components/shared/FAQSection.astro';
import CTABanner from '@/components/shared/CTABanner.astro';
import LeaderCard from '@/components/shared/LeaderCard.astro';
import OrgChart from '@/components/shared/OrgChart.astro';
import CredentialCard from '@/components/shared/CredentialCard.astro';
import { Image } from 'astro:assets';
import aboutHero from '@/assets/images/hero/about-hero.jpg';
import {
  generateMetadata,
  generateBreadcrumbJsonLd,
  generateOrganizationJsonLd,
  type BreadcrumbItem,
} from '@/lib/seo';

const page = await getEntry('pages', 'about');
if (!page) throw new Error('Missing content: pages/about.mdx');

const { Content } = await render(page);
const { mission, vision, values } = page.data;

const leaders = (await getCollection('team')).sort((a, b) => a.data.sortOrder - b.data.sortOrder);
const credentials = (await getCollection('credentials')).sort((a, b) => a.data.sortOrder - b.data.sortOrder);

const breadcrumbs: BreadcrumbItem[] = [
  { label: 'Home', href: '/' },
  { label: 'About the Group' },
];

const SITE_URL = (import.meta.env.SITE ?? 'https://globalresourcescitadel.com').replace(/\/$/, '');

const seo = {
  ...generateMetadata({
    title: 'About Us — Our Story, Mission & Leadership',
    description: page.data.seoDescription,
    path: '/about/',
  }),
  jsonLd: [
    generateBreadcrumbJsonLd(breadcrumbs),
    generateOrganizationJsonLd(),
    {
      '@context': 'https://schema.org',
      '@type': 'AboutPage',
      name: 'About Global Resources Citadel',
      url: `${SITE_URL}/about/`,
    },
  ],
};

const anchorItems = [
  { label: 'Overview', href: '#overview' },
  { label: 'Mission & Vision', href: '#mission-vision' },
  { label: 'Leadership', href: '#leadership' },
  { label: 'Group Structure', href: '#group-structure' },
  { label: 'Community Impact', href: '#community-impact' },
  { label: 'Credentials', href: '#credentials' },
];

const VALUE_ICONS: Record<string, string> = {
  shield: '🛡️',
  target: '🎯',
  users: '🤝',
  sprout: '🌱',
};

const visibleCredentials = credentials.slice(0, 6);
const hiddenCredentials = credentials.slice(6);
---

<PageLayout seo={seo}>
  <BreadcrumbNav items={breadcrumbs} slot="breadcrumb" />

  {/* Hero */}
  <SectionWrapper variant="primary">
    <div class="mx-auto max-w-3xl text-center">
      <p class="mb-4 text-xs font-semibold uppercase tracking-widest text-gold-600">
        About the Group
      </p>
      <h1 class="font-heading text-3xl font-bold leading-tight tracking-tight lg:text-5xl">
        Who We Are
      </h1>
      <p class="mx-auto mt-5 max-w-2xl text-lg leading-relaxed text-neutral-600">
        A pan-African conglomerate headquartered in Lagos, building integrated value chains across agriculture, trade, real estate, and energy — from Nigeria's strongest foundations to Africa's fastest-growing markets.
      </p>
    </div>
  </SectionWrapper>

  {/* Anchor navigation */}
  <AnchorNav items={anchorItems} />

  {/* ── Overview ── */}
  <SectionWrapper variant="default" id="overview">
    <div class="grid grid-cols-1 gap-8 lg:grid-cols-2 lg:gap-12">
      <Image
        src={aboutHero}
        alt="Business professionals collaborating in a modern office"
        width={800}
        height={500}
        class="aspect-video rounded-xl object-cover"
        loading="lazy"
      />

      <div>
        <SectionHeading>Our Story</SectionHeading>
        <div class="prose prose-lg max-w-none text-neutral-600">
          <Content />
        </div>
        <div class="mt-6 flex flex-wrap gap-4">
          <div class="rounded-full bg-primary-50 px-4 py-1.5 text-sm font-medium text-primary-700">
            Founded 2011
          </div>
          <div class="rounded-full bg-primary-50 px-4 py-1.5 text-sm font-medium text-primary-700">
            Headquarters: Lagos, Nigeria
          </div>
          <div class="rounded-full bg-primary-50 px-4 py-1.5 text-sm font-medium text-primary-700">
            7 Business Divisions
          </div>
        </div>
      </div>
    </div>
  </SectionWrapper>

  {/* ── Mission & Vision ── */}
  <SectionWrapper variant="light" id="mission-vision">
    <SectionHeading centered>
      Mission &amp; Vision
    </SectionHeading>

    {(mission || vision) && (
      <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
        {mission && (
          <div class="rounded-xl border border-neutral-200 bg-white p-8">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-primary-100 text-xl" aria-hidden="true">
              🎯
            </div>
            <h3 class="font-heading text-lg font-semibold text-neutral-900">Our Mission</h3>
            <p class="mt-3 text-sm leading-relaxed text-neutral-600">{mission}</p>
          </div>
        )}

        {vision && (
          <div class="rounded-xl border border-neutral-200 bg-white p-8">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-primary-100 text-xl" aria-hidden="true">
              🔭
            </div>
            <h3 class="font-heading text-lg font-semibold text-neutral-900">Our Vision</h3>
            <p class="mt-3 text-sm leading-relaxed text-neutral-600">{vision}</p>
          </div>
        )}
      </div>
    )}

    {values && values.length > 0 && (
      <div class="mt-10 grid grid-cols-2 gap-6 md:grid-cols-4">
        {values.map((v) => (
          <div class="text-center">
            <div class="mx-auto mb-3 flex h-10 w-10 items-center justify-center rounded-full bg-primary-50 text-lg" aria-hidden="true">
              {VALUE_ICONS[v.icon] ?? '✦'}
            </div>
            <h4 class="font-heading text-sm font-semibold text-neutral-900">{v.title}</h4>
            <p class="mt-1 text-xs leading-relaxed text-neutral-500">{v.description}</p>
          </div>
        ))}
      </div>
    )}
  </SectionWrapper>

  {/* ── Leadership ── */}
  <SectionWrapper variant="default" id="leadership">
    <SectionHeading centered subtitle="The team guiding GRCL's strategic direction and operational governance.">
      Leadership
    </SectionHeading>
    <div class="grid grid-cols-2 gap-6 md:grid-cols-3 lg:grid-cols-4">
      {leaders.map((leader) => (
        <LeaderCard
          name={leader.data.name}
          title={leader.data.title}
          briefDescriptor={leader.data.briefDescriptor}
          bio={leader.data.bio}
          photo={leader.data.photo}
        />
      ))}
    </div>
  </SectionWrapper>

  {/* ── Group Structure ── */}
  <SectionWrapper variant="light" id="group-structure">
    <SectionHeading centered subtitle="Our divisions operate within three strategic clusters, creating an integrated value chain.">
      How Our Divisions Connect
    </SectionHeading>
    <OrgChart />
    <div class="mx-auto mt-10 max-w-2xl text-center">
      <p class="text-lg leading-relaxed text-neutral-600">
        Each cluster groups complementary divisions that share supply chains, market knowledge, and operational infrastructure. This structure enables GRCL to capture value at every stage — from primary production through processing, trading, and distribution — across multiple African markets.
      </p>
      <a
        href="/divisions/"
        class="mt-6 inline-flex items-center gap-1.5 text-sm font-semibold text-primary-600 motion-safe:transition-colors hover:text-primary-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 focus-visible:ring-offset-2"
      >
        Explore Our Divisions <span aria-hidden="true">&rarr;</span>
      </a>
    </div>
  </SectionWrapper>

  {/* ── Community Impact ── */}
  <SectionWrapper variant="default" id="community-impact">
    <SectionHeading centered>
      Giving Back Through SRADA
    </SectionHeading>
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-lg leading-relaxed text-neutral-600">
        The Support Rural Agricultural Development Association (SRADA) is GRCL's dedicated social impact initiative, founded to channel the Group's agricultural expertise into sustainable rural community development across Africa.
      </p>
      <p class="mt-4 text-lg leading-relaxed text-neutral-600">
        While our commercial divisions build integrated value chains at industrial scale, SRADA works at the grassroots — training smallholder farmers, improving access to quality agricultural inputs, and strengthening the rural infrastructure that underpins Africa's food security.
      </p>
      <p class="mt-4 text-lg leading-relaxed text-neutral-600">
        SRADA represents our belief that lasting business success and community prosperity are inseparable.
      </p>
      <a
        href="/community-impact/"
        class="mt-6 inline-flex items-center gap-1.5 text-sm font-semibold text-primary-600 motion-safe:transition-colors hover:text-primary-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 focus-visible:ring-offset-2"
      >
        Learn More About Our Impact <span aria-hidden="true">&rarr;</span>
      </a>
    </div>
  </SectionWrapper>

  {/* ── Credentials ── */}
  <SectionWrapper variant="default" id="credentials">
    <SectionHeading centered>
      Credentials &amp; Certifications
    </SectionHeading>
    <div class="grid grid-cols-2 gap-6 md:grid-cols-3">
      {visibleCredentials.map((cred) => (
        <CredentialCard
          name={cred.data.name}
          issuer={cred.data.issuer}
        />
      ))}
    </div>

    {hiddenCredentials.length > 0 && (
      <details class="mt-6">
        <summary class="min-h-11 cursor-pointer text-sm font-semibold text-primary-600 hover:text-primary-700 focus-visible:rounded focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 focus-visible:ring-offset-2">
          Show All ({credentials.length} total)
        </summary>
        <div class="mt-4 grid grid-cols-2 gap-6 md:grid-cols-3">
          {hiddenCredentials.map((cred) => (
            <CredentialCard
              name={cred.data.name}
              issuer={cred.data.issuer}
              scope={typeof cred.data.scope === 'string' ? cred.data.scope : 'company-wide'}
            />
          ))}
        </div>
      </details>
    )}
  </SectionWrapper>

  {/* ── FAQ ── */}
  <FAQSection category="about" sectionTitle="Common Questions" />

  {/* ── CTA Band ── */}
  <CTABanner
    heading="Interested in Working With Us?"
    body="Whether you're a prospective partner, investor, or customer — we'd welcome the conversation."
    primaryCta={{ label: 'Contact Us', href: '/contact/' }}
    secondaryCta={{ label: 'Explore Divisions', href: '/divisions/' }}
  />
</PageLayout>
